# PageSpeed Insights API key (required for performance analysis)
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Ollama cloud API key (required for AI recommendations)
OLLAMA_API_KEY=your_ollama_api_key_here

# Node environment (development | production)
NODE_ENV=development

# CORS — comma-separated list of allowed origins (production only)
# In production, set this to your Vercel frontend domain:
# ALLOWED_ORIGINS=https://auditiq-ezyd.vercel.app
ALLOWED_ORIGINS=

# Puppeteer executable path (auto-detected by postinstall script)
# PUPPETEER_EXECUTABLE_PATH=

# Port (default: 7860)
# PORT=7860